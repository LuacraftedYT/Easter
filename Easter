print("🥔 [AWS EXPLOIT] Carrot Potato Mode Activated! FPS Boosting...")

task.spawn(function()
    while true do
        local gameObjects = Workspace:FindFirstChild("GameObjects")
        local carrotsFolder = gameObjects and gameObjects:FindFirstChild("Carrots")
        
        if carrotsFolder then
            for _, carrot in ipairs(carrotsFolder:GetChildren()) do
                if not carrot:GetAttribute("IsHidden") then
                    carrot:SetAttribute("IsHidden", true)
                    for _, part in ipairs(carrot:GetDescendants()) do
                        if part:IsA("BasePart") or part:IsA("MeshPart") then
                            part.Transparency = 1
                            part.CanCollide = false
                            part.CastShadow = false
                        elseif part:IsA("ParticleEmitter") or part:IsA("Trail") then
                            part.Enabled = false
                        elseif part:IsA("Decal") or part:IsA("Texture") then
                            part.Transparency = 1
                        end
                    end
                    if carrot:IsA("BasePart") or carrot:IsA("MeshPart") then
                        carrot.Transparency = 1
                        carrot.CanCollide = false
                        carrot.CastShadow = false
                    end
                end
            end
        end
        task.wait(1)
    end
end)
