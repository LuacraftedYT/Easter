-- ENGINE 1: MAGNET HARVESTER
local farming = false
local totalHarvested = 0
HarvestBtn.MouseButton1Click:Connect(function()
    farming = not farming
    if farming then
        HarvestBtn.Text = "ON | Magnet Farm"
        HarvestBtn.BackgroundColor3 = Color3.fromRGB(0, 150, 0)
        task.spawn(function()
            while farming do
                local char = LocalPlayer.Character
                if char and char:FindFirstChild("HumanoidRootPart") then
                    local root = char.HumanoidRootPart
                    local gameObjects = Workspace:FindFirstChild("GameObjects")
                    local carrotsFolder = gameObjects and gameObjects:FindFirstChild("Carrots")
                    
                    if carrotsFolder then
                        for _, carrot in ipairs(carrotsFolder:GetChildren()) do
                            if not farming then break end 
                            local cZone = carrot:GetAttribute("CarrotZone")
                            local guid = carrot:GetAttribute("CarrotGuid")
                            if cZone and guid and (carrot:IsA("BasePart") or carrot:IsA("Model")) then
                                if carrot:IsA("Model") then
                                    carrot:PivotTo(root.CFrame)
                                else
                                    carrot.CFrame = root.CFrame
                                end
                                task.spawn(function()
                                    local success, result = pcall(function() return CarrotRemote:InvokeServer(cZone, guid) end)
                                    if success and result == true then
                                        totalHarvested = totalHarvested + 1
                                        CounterLbl.Text = "✅ Verified: " .. tostring(totalHarvested)
                                        if carrot and carrot.Parent then carrot:Destroy() end
                                    end
                                end)
                                task.wait(0.02) -- ⚡ SUPERCHARGED SPEED TO 0.02
                            end
                        end
                    end
                end
                task.wait(0.1) 
            end
        end)
    else
        HarvestBtn.Text = "OFF | Magnet Farm"
        HarvestBtn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    end
end)

