-- COLLECTION LOGIC
local function collectNearby()
    local gameObjects = Workspace:FindFirstChild("GameObjects")
    local carrotsFolder = gameObjects and gameObjects:FindFirstChild("Carrots")
    if not carrotsFolder or not isWalking then return end

    local root = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
    if not root then return end

    for _, carrot in ipairs(carrotsFolder:GetChildren()) do
        local cZone, guid = carrot:GetAttribute("CarrotZone"), carrot:GetAttribute("CarrotGuid")
        if cZone and guid and not carrot:GetAttribute("Processed") then
            local carrotPos = carrot:IsA("Model") and carrot:GetPivot().Position or carrot.Position
            if (carrotPos - root.Position).Magnitude < (stepSize + 5) then
                carrot:SetAttribute("Processed", true)
                for _, p in ipairs(carrot:GetDescendants()) do if p:IsA("BasePart") then p.Transparency = 1; p.CanCollide = false end end
                
                table.insert(batchQueue, {cZone, guid})
                if #batchQueue >= 4 then
                    local pld = batchQueue; batchQueue = {}
                    task.spawn(function()
                        if BatchRemote:InvokeServer(pld) then 
                            totalHarvested = totalHarvested + #pld
                            CounterLbl.Text = "✅ Collected: " .. totalHarvested
                        end
                    end)
                end
            end
        end
    end
end

-- MOVEMENT ENGINE
local function runCoverage()
    local function getPath()
        local pts = {} local up = true
        for x = minX, maxX, stepSize do
            if up then for z = minZ, maxZ, stepSize do table.insert(pts, Vector3.new(x, fixedY, z)) end
            else for z = maxZ, minZ, -stepSize do table.insert(pts, Vector3.new(x, fixedY, z)) end end
            up = not up
        end return pts
    end
    while isWalking do
        for _, pt in ipairs(getPath()) do
            if not isWalking then break end
            local char = LocalPlayer.Character
            local hum = char and char:FindFirstChildOfClass("Humanoid")
            local root = char and char:FindFirstChild("HumanoidRootPart")
            if not hum or not root or hum.Health <= 0 then task.wait(2) break end
            
            hum:MoveTo(pt)
            local reached = false
            local conn = hum.MoveToFinished:Connect(function() reached = true end)
            
            while not reached and isWalking do
                task.wait(0.1); collectNearby()
                -- Safety Fix: Check root existence inside loop
                local currentRoot = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                if currentRoot and (currentRoot.Position - pt).Magnitude < 3 then reached = true end
            end
            if conn then conn:Disconnect() end
        end
        task.wait(0.5)
    end
end

